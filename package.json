{
  "name": "usemint-cli",
  "version": "0.3.0-beta.1",
  "description": "Zero-setup AI coding CLI — type mint, start coding",
  "type": "module",
  "bin": {
    "mint": "./dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/cli/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ai",
    "coding",
    "cli",
    "llm",
    "deepseek",
    "anthropic"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@google/generative-ai": "^0.24.1",
    "better-sqlite3": "^12.8.0",
    "boxen": "^8.0.1",
    "chalk": "^5.3.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.1.0",
    "conf": "^13.0.1",
    "diff": "^8.0.4",
    "glob": "^11.0.0",
    "ignore": "^6.0.2",
    "ink": "^5.0.1",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "open": "^10.1.0",
    "openai": "^4.67.0",
    "ora": "^8.1.0",
    "pino": "^10.3.1",
    "react": "^18.3.1",
    "tiktoken": "^1.0.16",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^6.0.0",
    "@types/node": "^22.7.0",
    "@types/react": "^18.3.9",
    "tsup": "^8.3.0",
    "typescript": "^5.6.2",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
